# ─── Runtime ───────────────────────────────────────────────────────────────
# Use "production" on Hostinger / public deployment.
NODE_ENV="development"

# Public URL of the deployed app (HTTPS in production).
# Used for OAuth callbacks, UploadThing, email links, and CORS.
APP_URL="https://axelmond.com"

# Extra CORS origins, comma-separated (optional if APP_URL is enough).
# Example: https://www.axelmond.com,https://admin.axelmond.com
ALLOWED_ORIGINS="https://www.axelmond.com"

# Server port (default 3000).
PORT="3000"

# Skip demo seed on production boot (migrations already provision taxonomy).
# Set to "true" only for manual re-sync in staging.
RUN_STARTUP_SEED="false"

# Optional PostgreSQL pool size for Prisma driver adapter (default 5).
# DATABASE_POOL_MAX="5"

# Optional frontend override when API is on a different host than the SPA.
VITE_API_BASE_URL=""

# ─── Authentication ────────────────────────────────────────────────────────
# Required in production — generate a unique random string (32+ chars).
AUTH_TOKEN_SECRET="MY_AUTH_TOKEN_SECRET"
# Required in production — must be different from AUTH_TOKEN_SECRET.
EMAIL_VERIFICATION_SECRET="MY_EMAIL_VERIFICATION_SECRET"

# Optional — only needed for native mobile API (not WebView shell).
# EXPO_PUBLIC_MOBILE_API_SECRET must match when set.
# MOBILE_API_SECRET="MY_MOBILE_API_SECRET"

# Brute-force protection on /api/auth/login
AUTH_MAX_ATTEMPTS="20"
AUTH_LOCKOUT_WINDOW_MS="60000"

# ─── PayPal (server-side secret + public client id for SDK) ───────────────
PAYPAL_CLIENT_ID="MY_PAYPAL_CLIENT_ID"
PAYPAL_CLIENT_SECRET="MY_PAYPAL_CLIENT_SECRET"
# Use "Sandbox" for development/tests, "live" is mandatory when NODE_ENV="production".
PAYPAL_ENV="Sandbox"
# PayPal checkout currency (MAD is not supported on most live business accounts — use USD).
PAYPAL_CURRENCY_CODE="USD"
# Conversion applied when checkout currency differs from displayed MAD prices (128 MAD -> 12.80 USD at 0.1).
PAYPAL_MAD_TO_USD_RATE="0.1"
# Webhook ID from PayPal Developer Dashboard (Apps & Credentials → Webhooks).
PAYPAL_WEBHOOK_ID="MY_PAYPAL_WEBHOOK_ID"

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/axelmond_research_labs?schema=AxelmondResearchLab"

# ─── LiveKit (server-side only) ──────────────────────────────────────────
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="MY_LIVEKIT_API_KEY"
LIVEKIT_API_SECRET="MY_LIVEKIT_API_SECRET"

# ─── UploadThing (server-side only) ──────────────────────────────────────
UPLOADTHING_TOKEN="MY_UPLOADTHING_TOKEN"
UPLOADTHING_CALLBACK_URL="http://localhost:3000/api/uploadthing"
# Set to "false" in production.
UPLOADTHING_IS_DEV="true"

# ─── Email / SMTP ────────────────────────────────────────────────────────
EMAIL_FROM="Axelmond Research Labs <verification@axelmond.com>"
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="verification@axelmond.com"
SMTP_PASS="MY_SMTP_PASSWORD"
EMAIL_VERIFICATION_URL="http://localhost:3000"

# ─── AI tutor (server-side only) ─────────────────────────────────────────
OPENAI_API_KEY="MY_OPENAI_API_KEY"
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL="gpt-4o-mini"
# OPENAI_TIMEOUT_MS="60000"
# OPENAI_MAX_OUTPUT_TOKENS="4096"

# ─── Invitations ─────────────────────────────────────────────────────────
PROFESSOR_INVITE_CODES="PROF-INVITE-001,PROF-INVITE-002"

# ─── Monitoring (optional) ───────────────────────────────────────────────
# HEALTH_CHECK_TOKEN="MY_HEALTH_CHECK_TOKEN"
# LOG_LEVEL="info"
# RATE_LIMIT_MAX="5000"

# ─── Web Push (notifications navigateur) ───────────────────────────────────
VAPID_PUBLIC_KEY="MY_VAPID_PUBLIC_KEY"
VAPID_PRIVATE_KEY="MY_VAPID_PRIVATE_KEY"
VAPID_SUBJECT="mailto:support@axelmond.com"
