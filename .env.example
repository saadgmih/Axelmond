# ─── Runtime ───────────────────────────────────────────────────────────────
# Use "production" on Hostinger / public deployment.
NODE_ENV="development"

# Public URL of the deployed app (HTTPS in production).
# Used for OAuth callbacks, UploadThing, email links, and CORS.
APP_URL="https://axelmond.com"

# Extra CORS origins, comma-separated (optional if APP_URL is enough).
# Example: https://www.axelmond.com,https://admin.axelmond.com
ALLOWED_ORIGINS="https://www.axelmond.com"

# Server port (default 3000).
PORT="3000"

# Express trust proxy hops (Cloudflare → Hostinger). Use "1" with Cloudflare orange-cloud.
# If client IPs look wrong in logs/rate limits, try "2" or "true".
# TRUST_PROXY="1"

# Skip demo seed on production boot (migrations already provision taxonomy).
# Set to "true" only for manual re-sync in staging.
RUN_STARTUP_SEED="false"

# Hostinger Node.js Web App — set all three in hPanel (not needed locally).
# HOSTINGER_WEBAPP="1"
# SKIP_PRISMA_POSTINSTALL="1"
# GRACEFUL_SHUTDOWN_MS="3000"
# DATABASE_POOL_MAX="5"

# Optional frontend override when API is on a different host than the SPA.
VITE_API_BASE_URL=""

# ─── Authentication ────────────────────────────────────────────────────────
# Required in production — generate a unique random string (32+ chars).
AUTH_TOKEN_SECRET="MY_AUTH_TOKEN_SECRET"
# Required in production — must be different from AUTH_TOKEN_SECRET.
EMAIL_VERIFICATION_SECRET="MY_EMAIL_VERIFICATION_SECRET"

# Native mobile apps use X-Axelmond-Client + X-Axelmond-Client-Key (required in production).
# Generate a unique random string (32+ chars) shared with EXPO_PUBLIC_MOBILE_CLIENT_KEY.
# Do NOT use MOBILE_API_SECRET — that name is ignored by the server.
MOBILE_CLIENT_SECRET="MY_MOBILE_CLIENT_SECRET"

# WebAuthn / passkeys (production: apex domain without scheme).
# WEBAUTHN_RP_ID="axelmond.com"
# WEBAUTHN_RP_NAME="Performance Académique"

# Optional: block professor/researcher/admin API access until TOTP or Passkey is configured.
# Default is false — MFA remains voluntary; users configure it from Sécurité du compte.
# PRIVILEGED_MFA_SETUP_REQUIRED="false"

# Bcrypt cost factor (default 12).
# BCRYPT_ROUNDS="12"

# Reject passwords when HIBP is unreachable in production (default fail-closed).
# HIBP_FAIL_OPEN="false"

# Promo codes are disabled in production unless explicitly enabled.
# PROMO_CODES_ENABLED="false"
# PROMO_CODES_DISABLED="false"

# Dev/staging only — mock course enrollment (blocked in production).
# ALLOW_MOCK_ENROLLMENT="false"

# ALLOW_DEV_VERIFICATION_CODE_LOG="false"

# Auth user DB cache TTL in ms (default 5000)
# AUTH_USER_CACHE_MS="5000"
# Max auth user cache entries (default 200)
# AUTH_USER_CACHE_MAX_ENTRIES="200"

# In-memory API cache (default 100 entries, 512KB max per value)
# CACHE_MAX_ENTRIES="100"
# CACHE_MAX_VALUE_BYTES="512000"
# CACHE_TTL_SECONDS="60"

# Performance monitor interval in ms (default 120000)
# PERF_MONITOR_INTERVAL_MS="120000"
# PERF_ROUTE_STATS_MAX="100"

# Socket.io auth cache and buffers
# SOCKET_AUTH_CACHE_MS="5000"
# SOCKET_AUTH_CACHE_MAX_ENTRIES="200"
# SOCKET_MAX_HTTP_BUFFER_BYTES="1000000"
# Disable HIBP password breach checks (enabled by default except in test)
# HIBP_CHECK_DISABLED="false"

# ─── PayPal (server-side secret + public client id for SDK) ───────────────
PAYPAL_CLIENT_ID="MY_PAYPAL_CLIENT_ID"
PAYPAL_CLIENT_SECRET="MY_PAYPAL_CLIENT_SECRET"
# Use "Sandbox" for development/tests, "live" is mandatory when NODE_ENV="production".
PAYPAL_ENV="Sandbox"
# PayPal checkout currency (MAD is not supported on most live business accounts — use USD).
PAYPAL_CURRENCY_CODE="USD"
# Conversion applied when checkout currency differs from displayed MAD prices (128 MAD -> 12.80 USD at 0.1).
PAYPAL_MAD_TO_USD_RATE="0.1"
# Webhook ID from PayPal Developer Dashboard (Apps & Credentials → Webhooks).
PAYPAL_WEBHOOK_ID="MY_PAYPAL_WEBHOOK_ID"

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/axelmond_research_labs?schema=AxelmondResearchLab&sslmode=verify-full"

# ─── LiveKit (server-side only) ──────────────────────────────────────────
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="MY_LIVEKIT_API_KEY"
LIVEKIT_API_SECRET="MY_LIVEKIT_API_SECRET"

# ─── UploadThing (server-side only) ──────────────────────────────────────
UPLOADTHING_TOKEN="MY_UPLOADTHING_TOKEN"
UPLOADTHING_CALLBACK_URL="http://localhost:3000/api/uploadthing"
# Set to "false" in production.
UPLOADTHING_IS_DEV="true"

# ─── Email / SMTP ────────────────────────────────────────────────────────
EMAIL_FROM="Performance Académique <verification@axelmond.com>"
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="verification@axelmond.com"
SMTP_PASS="MY_SMTP_PASSWORD"
EMAIL_VERIFICATION_URL="http://localhost:3000"

# ─── Optional marketing voiceover utility (not used by the web app) ──────
# OPENAI_API_KEY="MY_OPENAI_API_KEY"
# COURSE_MODULES_READ_RELATIONAL="false"

# ─── Invitations ─────────────────────────────────────────────────────────
PROFESSOR_INVITE_CODES="PROF-INVITE-001,PROF-INVITE-002"

# ─── Monitoring (optional) ───────────────────────────────────────────────
# HEALTH_CHECK_TOKEN="MY_HEALTH_CHECK_TOKEN"
# LOG_LEVEL="info"
# RATE_LIMIT_WINDOW_MS="900000"
# RATE_LIMIT_MAX_REQUESTS="500"

# ─── Cache / Redis (optional) ────────────────────────────────────────────
# Public catalog cache TTL in seconds (default 60).
# CACHE_TTL_SECONDS="60"
# CACHE_MAX_ENTRIES="1000"
# Distributed cache for PM2 cluster (required before enabling cluster mode).
# REDIS_URL="redis://localhost:6379"
# REDIS_KEY_PREFIX="axelmond:cache:"
# PM2 cluster worker count when REDIS_URL is set (default: all CPUs).
# PM2_INSTANCES="2"
# Log every successful RBAC check (default: denials only).
# RBAC_VERBOSE_LOGGING="false"

# ─── Web Push (notifications navigateur) ───────────────────────────────────
VAPID_PUBLIC_KEY="MY_VAPID_PUBLIC_KEY"
VAPID_PRIVATE_KEY="MY_VAPID_PRIVATE_KEY"
VAPID_SUBJECT="mailto:support@axelmond.com"
# Optional — max devices per user (default: 5).
# PUSH_MAX_SUBSCRIPTIONS_PER_USER="5"
#
# Optional — restrict push provider host suffixes (HTTPS only).
# RECOMMENDED: leave PUSH_ALLOWED_HOST_SUFFIXES UNSET so all major browsers work:
#   Chrome, Brave, Opera, Vivaldi, Samsung Internet, Firefox, Safari, Edge (Windows).
# Only set this if you intentionally want to narrow providers.
# PUSH_ALLOWED_HOST_SUFFIXES="fcm.googleapis.com,updates.push.services.mozilla.com,push.services.mozilla.com,web.push.apple.com,notify.windows.com"
