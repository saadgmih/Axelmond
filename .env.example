# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional frontend override. Leave empty when Express serves the Vite app on localhost:3000.
VITE_API_BASE_URL=""

# Authentication brute-force protection.
AUTH_MAX_ATTEMPTS="20"
AUTH_LOCKOUT_WINDOW_MS="60000"
AUTH_TOKEN_SECRET="MY_AUTH_TOKEN_SECRET"

# Stripe: server-side only. Used for checkout sessions and webhook verification.
STRIPE_SECRET_KEY="sk_test_MY_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="whsec_MY_STRIPE_WEBHOOK_SECRET"

# PostgreSQL database used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/axelmond_research_labs?schema=public"

# LiveKit Cloud: server-side only. Never expose LIVEKIT_API_SECRET in frontend code.
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="MY_LIVEKIT_API_KEY"
LIVEKIT_API_SECRET="MY_LIVEKIT_API_SECRET"

# UploadThing: server-side only. Used by /api/uploadthing to generate presigned uploads.
UPLOADTHING_TOKEN="MY_UPLOADTHING_TOKEN"
UPLOADTHING_CALLBACK_URL="http://localhost:3000/api/uploadthing"
UPLOADTHING_IS_DEV="true"

# Professor invite codes: server-side seed only, comma-separated, one use per professor account.
PROFESSOR_INVITE_CODES="PROF-INVITE-001,PROF-INVITE-002"

# Email verification: server-side only. SMTP is required to receive real 6-digit codes.
EMAIL_FROM="Axelmond Research Labs <verification@axelmond.com>"
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="verification@axelmond.com"
SMTP_PASS="MY_SMTP_PASSWORD"
EMAIL_VERIFICATION_SECRET="MY_EMAIL_VERIFICATION_SECRET"
EMAIL_VERIFICATION_URL="http://localhost:3000"
