{
  "expo": {
    "name": "Performance Académique",
    "slug": "axelmond-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "axelmond",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.axelmond.researchlabs",
      "infoPlist": {
        "NSCameraUsageDescription": "L'application utilise la caméra pour participer aux cours en direct.",
        "NSMicrophoneUsageDescription": "L'application utilise le microphone pour participer aux cours en direct.",
        "UIBackgroundModes": ["audio"]
      },
      "bitcode": false
    },
    "android": {
      "package": "com.axelmond.researchlabs",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-dev-client",
      [
        "expo-camera",
        {
          "cameraPermission": "L'application utilise la caméra pour participer aux cours en direct.",
          "microphonePermission": "L'application utilise le microphone pour participer aux cours en direct.",
          "recordAudioAndroid": true
        }
      ],
      [
        "@livekit/react-native-expo-plugin",
        {
          "android": {
            "audioType": "communication"
          }
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "L'application utilise la caméra pour participer aux cours en direct.",
          "microphonePermission": "L'application utilise le microphone pour participer aux cours en direct."
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f172a",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#0f172a"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "19fe7b32-62c0-4ad5-9d05-9ba343f69317"
      }
    },
    "owner": "gmihsaad"
  }
}
