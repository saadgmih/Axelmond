{
  "expo": {
    "name": "Axelmond Research Labs",
    "slug": "axelmond-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "axelmond",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.axelmond.researchlabs",
      "infoPlist": {
        "NSCameraUsageDescription": "Axelmond utilise la caméra pour participer aux cours en direct.",
        "NSMicrophoneUsageDescription": "Axelmond utilise le microphone pour participer aux cours en direct.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "com.axelmond.researchlabs",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-dev-client",
      [
        "expo-camera",
        {
          "cameraPermission": "Axelmond utilise la caméra pour participer aux cours en direct.",
          "microphonePermission": "Axelmond utilise le microphone pour participer aux cours en direct.",
          "recordAudioAndroid": true
        }
      ],
        "@livekit/react-native-expo-plugin",
        {
          "android": {
            "audioType": "communication"
          }
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Axelmond utilise la caméra pour participer aux cours en direct.",
          "microphonePermission": "Axelmond utilise le microphone pour participer aux cours en direct."
        }
      ]
    ]
  }
}
