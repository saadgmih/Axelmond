generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["AxelmondResearchLab"]
}

enum UserRole {
  STUDENT
  PROFESSOR
  RESEARCHER
  ADMIN

  @@schema("AxelmondResearchLab")
}

enum OnboardingFlow {
  STUDENT
  TEACHER
  ADMIN

  @@schema("AxelmondResearchLab")
}

enum OnboardingStatus {
  IN_PROGRESS
  COMPLETED
  DISMISSED

  @@schema("AxelmondResearchLab")
}

enum LessonContentType {
  VIDEO
  PDF
  IMAGE
  TEXT

  @@schema("AxelmondResearchLab")
}

enum AttachmentType {
  VIDEO
  PDF
  IMAGE
  FILE

  @@schema("AxelmondResearchLab")
}

enum LessonContentStatus {
  DRAFT
  PROCESSING
  READY
  PUBLISHED
  FAILED

  @@schema("AxelmondResearchLab")
}

enum VideoJobStatus {
  UPLOADED
  QUEUED
  VALIDATING
  PROBING
  NORMALIZING
  ADDING_INTRO
  ENCODING
  VERIFYING
  READY
  FAILED
  CANCELLED

  @@schema("AxelmondResearchLab")
}

model User {
  id                       String                        @id @default(cuid())
  email                    String                        @unique
  passwordHash             String
  fullName                 String
  role                     UserRole
  emailVerified            Boolean                       @default(false)
  levelOrTitle             String?
  filiere                  String?
  avatarUrl                String?
  failedLoginAttempts      Int                           @default(0)
  lockoutUntil             DateTime?
  totpEnabled              Boolean                       @default(false)
  totpSecretEnc            String?
  authTokenVersion         Int                           @default(0)
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt
  enrollments              Enrollment[]
  liveSessions             LiveSession[]                 @relation("ProfessorLiveSessions")
  liveMessages             LiveMessage[]
  usedInviteCodes          ProfessorInviteCode[]         @relation("UsedInviteCodes")
  createdInviteCodes       ProfessorInviteCode[]         @relation("CreatedInviteCodes")
  createdCourses           Course[]                      @relation("CreatedCourses")
  createdChapters          Chapter[]                     @relation("CreatedChapters")
  createdSections          ContentSection[]              @relation("CreatedSections")
  createdContents          LessonContent[]               @relation("CreatedContents")
  createdAttachments       Attachment[]                  @relation("CreatedAttachments")
  emailVerificationCodes   EmailVerificationCode[]
  emailDeliveryLogs        EmailDeliveryLog[]
  academicProfile          AcademicProfile?
  quizAttempts             QuizAttempt[]
  moduleProgress           ModuleProgress[]
  contentProgress          StudentContentProgress[]
  refreshTokens            RefreshToken[]
  auditLogs                AuditLog[]
  liveAttendances          LiveAttendance[]
  liveActionLogs           LiveActionLog[]               @relation("LiveActionActor")
  scheduleSessions         ProfessorScheduleSession[]
  studyScheduleSessions    StudentStudyScheduleSession[]
  objectives               StudentObjective[]
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]                     @relation("SentMessages")
  messageReads             MessageRead[]
  notifications            Notification[]
  pushSubscriptions        PushSubscription[]
  payments                 Payment[]
  invoiceRecords           Invoice[]
  centerPaymentRequests    CenterPaymentRequest[]        @relation("CenterPaymentStudent")
  validatedCenterPayments  CenterPaymentRequest[]        @relation("CenterPaymentValidator")
  centerPaymentChanges     CenterPaymentStatusHistory[]  @relation("CenterPaymentHistoryActor")
  totpRecoveryCodes        TotpRecoveryCode[]
  webAuthnCredentials      WebAuthnCredential[]
  securityChallenges       SecurityChallenge[]
  charityCodeUsages        CharityCodeUsage[]
  createdCharityCodes      CharityAccessCode[]           @relation("CreatedCharityCodes")
  charityDonations         Donation[]
  onboardingProgress       UserOnboarding[]
  createdPromoCodes        PromoCode[]                   @relation("PromoCodeCreator")
  eligiblePromoCodes       PromoCodeEligibleUser[]
  promoCodeUsages          PromoCodeUsage[]
  promoCodeAuditActions    PromoCodeAuditLog[]

  @@index([role])
  @@schema("AxelmondResearchLab")
}

model UserOnboarding {
  id          String           @id @default(cuid())
  userId      String
  flow        OnboardingFlow
  version     Int              @default(1)
  status      OnboardingStatus @default(IN_PROGRESS)
  currentStep Int              @default(0)
  completedAt DateTime?
  dismissedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, flow, version])
  @@index([userId, status])
  @@schema("AxelmondResearchLab")
}

model AcademicProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  title           String?
  department      String?
  lab             String?
  speciality      String?
  teachingDomains Json     @default("[]")
  researchDomains Json     @default("[]")
  bio             String?
  avatarUrl       String?
  links           Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("AxelmondResearchLab")
}

enum EmailVerificationPurpose {
  EMAIL_VERIFY
  PASSWORD_RESET

  @@schema("AxelmondResearchLab")
}

model EmailVerificationCode {
  id        String                   @id @default(cuid())
  userId    String
  purpose   EmailVerificationPurpose @default(EMAIL_VERIFY)
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int                      @default(0)
  createdAt DateTime                 @default(now())
  user      User                     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, usedAt, createdAt])
  @@index([userId, purpose, usedAt, createdAt])
  @@schema("AxelmondResearchLab")
}

model EmailDeliveryLog {
  id              String   @id @default(cuid())
  userId          String?
  purpose         String
  recipientDomain String
  smtp            Json
  messageId       String?
  accepted        Json
  rejected        Json
  envelope        Json?
  response        String?
  providerStatus  String
  createdAt       DateTime @default(now())
  user            User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@schema("AxelmondResearchLab")
}

model ProfessorInviteCode {
  code        String    @id
  createdAt   DateTime  @default(now())
  usedAt      DateTime?
  revokedAt   DateTime?
  usedById    String?
  createdById String?
  usedBy      User?     @relation("UsedInviteCodes", fields: [usedById], references: [id])
  createdBy   User?     @relation("CreatedInviteCodes", fields: [createdById], references: [id])

  @@index([usedAt, revokedAt])
  @@schema("AxelmondResearchLab")
}

model FacultyDomain {
  id          Int          @id
  name        String       @unique
  slug        String       @unique
  iconName    String
  color       String
  description String
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  disciplines Discipline[]

  @@schema("AxelmondResearchLab")
}

model Discipline {
  id        Int           @id
  domainId  Int
  name      String
  slug      String        @unique
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  domain    FacultyDomain @relation(fields: [domainId], references: [id])
  courses   Course[]

  @@index([domainId, order])
  @@schema("AxelmondResearchLab")
}

model Course {
  id                     Int                      @id @default(autoincrement())
  title                  String
  level                  String
  credits                Int
  duration               String
  category               String
  price                  Float
  freeAccessStartsAt     DateTime?
  freeAccessEndsAt       DateTime?
  freeAccessDurationDays Int?
  iconName               String
  color                  String
  imageUrl               String?
  imageKey               String?
  instructor             String
  description            String
  progress               Int                      @default(0)
  isLiveNow              Boolean                  @default(false)
  liveSubject            String?
  published              Boolean                  @default(true)
  disciplineId           Int
  createdById            String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  enrollments            Enrollment[]
  liveSessions           LiveSession[]
  discipline             Discipline               @relation(fields: [disciplineId], references: [id])
  createdBy              User?                    @relation("CreatedCourses", fields: [createdById], references: [id])
  chapters               Chapter[]
  sections               ContentSection[]
  contents               LessonContent[]
  attachments            Attachment[]
  quizzes                Quiz[]
  quizAttempts           QuizAttempt[]
  moduleProgress         ModuleProgress[]
  contentProgress        StudentContentProgress[]
  payments               Payment[]
  centerPaymentRequests  CenterPaymentRequest[]
  courseModules          CourseModule[]
  promoCodeModules       PromoCodeModule[]
  promoCodeUsages        PromoCodeUsage[]

  @@index([disciplineId])
  @@index([createdById])
  @@index([published])
  @@index([disciplineId, published])
  @@schema("AxelmondResearchLab")
}

model CourseModule {
  courseId        Int
  id              Int
  sortOrder       Int     @default(0)
  title           String
  type            String
  duration        String  @default("")
  contentMarkdown String?
  attachmentUrl   String?
  attachmentName  String?
  sectionId       String?
  published       Boolean @default(true)
  course          Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([courseId, id])
  @@index([courseId, sortOrder])
  @@schema("AxelmondResearchLab")
}

model Chapter {
  id          String           @id @default(cuid())
  courseId    Int
  title       String
  description String?
  order       Int              @default(0)
  published   Boolean          @default(false)
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  course      Course           @relation(fields: [courseId], references: [id])
  createdBy   User?            @relation("CreatedChapters", fields: [createdById], references: [id])
  sections    ContentSection[]

  @@index([courseId])
  @@index([createdById])
  @@schema("AxelmondResearchLab")
}

model ContentSection {
  id          String           @id @default(cuid())
  courseId    Int
  chapterId   String?
  parentId    String?
  title       String
  description String?
  order       Int              @default(0)
  published   Boolean          @default(false)
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  course      Course           @relation(fields: [courseId], references: [id])
  chapter     Chapter?         @relation(fields: [chapterId], references: [id])
  parent      ContentSection?  @relation("SectionChildren", fields: [parentId], references: [id])
  children    ContentSection[] @relation("SectionChildren")
  contents    LessonContent[]
  quizzes     Quiz[]
  createdBy   User?            @relation("CreatedSections", fields: [createdById], references: [id])

  @@index([courseId])
  @@index([chapterId])
  @@index([parentId])
  @@index([createdById])
  @@schema("AxelmondResearchLab")
}

model LessonContent {
  id          String              @id @default(cuid())
  courseId    Int
  sectionId   String?
  type        LessonContentType
  title       String
  body        String?
  published   Boolean             @default(false)
  status      LessonContentStatus @default(READY)
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  course      Course              @relation(fields: [courseId], references: [id])
  section     ContentSection?     @relation(fields: [sectionId], references: [id])
  createdBy   User?               @relation("CreatedContents", fields: [createdById], references: [id])
  attachments Attachment[]

  @@index([courseId])
  @@index([sectionId])
  @@index([createdById])
  @@schema("AxelmondResearchLab")
}

model Attachment {
  id          String         @id @default(cuid())
  courseId    Int
  contentId   String
  type        AttachmentType
  fileName    String
  fileKey     String
  url         String
  mimeType    String?
  size        Int
  createdById String?
  createdAt   DateTime       @default(now())
  course      Course         @relation(fields: [courseId], references: [id])
  content     LessonContent  @relation(fields: [contentId], references: [id])
  createdBy   User?          @relation("CreatedAttachments", fields: [createdById], references: [id])

  @@index([courseId])
  @@index([contentId])
  @@index([createdById])
  @@schema("AxelmondResearchLab")
}

model VideoProcessingJob {
  id               String         @id @default(cuid())
  contentId        String         @unique
  uploadedByUserId String
  sourceVideoPath  String
  outputVideoPath  String?
  introVersion     Int            @default(1)
  status           VideoJobStatus @default(UPLOADED)
  progressPercent  Int            @default(0)
  currentStep      String?
  sourceDuration   Float?
  outputDuration   Float?
  sourceSizeBytes  Int?
  outputSizeBytes  Int?
  errorCode        String?
  errorMessage     String?
  startedAt        DateTime?
  completedAt      DateTime?
  failedAt         DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([contentId])
  @@schema("AxelmondResearchLab")
}

model Enrollment {
  id                    String                 @id @default(cuid())
  userId                String
  courseId              Int
  active                Boolean                @default(true)
  hasAiAccess           Boolean                @default(false)
  startDate             DateTime               @default(now())
  endDate               DateTime?
  user                  User                   @relation(fields: [userId], references: [id])
  course                Course                 @relation(fields: [courseId], references: [id])
  centerPaymentRequests CenterPaymentRequest[]

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([courseId, active])
  @@index([userId])
  @@index([userId, active])
  @@schema("AxelmondResearchLab")
}

model Quiz {
  id        String          @id @default(cuid())
  courseId  Int
  moduleId  Int?
  sectionId String?
  title     String
  published Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  course    Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  section   ContentSection? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([courseId])
  @@index([courseId, moduleId])
  @@index([sectionId])
  @@schema("AxelmondResearchLab")
}

model QuizQuestion {
  id          String       @id @default(cuid())
  quizId      String
  question    String
  options     Json
  answer      String
  explanation String
  order       Int          @default(0)
  quiz        Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers     QuizAnswer[]

  @@index([quizId, order])
  @@schema("AxelmondResearchLab")
}

model QuizAttempt {
  id           String       @id @default(cuid())
  quizId       String
  courseId     Int
  moduleId     Int?
  userId       String
  score        Int
  total        Int
  scoreOutOf20 Float
  createdAt    DateTime     @default(now())
  quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers      QuizAnswer[]

  @@index([courseId, userId, createdAt])
  @@index([quizId, userId, createdAt])
  @@schema("AxelmondResearchLab")
}

model QuizAnswer {
  id             String        @id @default(cuid())
  attemptId      String
  questionId     String?
  selectedAnswer String
  isCorrect      Boolean
  attempt        QuizAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       QuizQuestion? @relation(fields: [questionId], references: [id], onDelete: SetNull)

  @@index([attemptId])
  @@schema("AxelmondResearchLab")
}

model LiveSession {
  id              String           @id @default(cuid())
  roomName        String           @unique
  title           String?
  courseId        Int
  professorId     String?
  isActive        Boolean          @default(true)
  startTime       DateTime         @default(now())
  endTime         DateTime?
  replayContentId String?
  recordingStatus String           @default("NONE")
  course          Course           @relation(fields: [courseId], references: [id])
  professor       User?            @relation("ProfessorLiveSessions", fields: [professorId], references: [id])
  messages        LiveMessage[]
  attendances     LiveAttendance[]
  actionLogs      LiveActionLog[]

  @@index([courseId])
  @@index([courseId, isActive])
  @@index([professorId])
  @@index([recordingStatus])
  @@schema("AxelmondResearchLab")
}

model LiveMessage {
  id        String       @id @default(cuid())
  clientId  String?      @unique
  roomName  String
  text      String
  createdAt DateTime     @default(now())
  sessionId String?
  userId    String?
  session   LiveSession? @relation(fields: [sessionId], references: [id])
  user      User?        @relation(fields: [userId], references: [id])

  @@index([roomName, createdAt])
  @@index([sessionId])
  @@index([userId])
  @@schema("AxelmondResearchLab")
}

model LiveAttendance {
  id                 String      @id @default(cuid())
  sessionId          String
  roomName           String
  userId             String?
  role               UserRole
  joinedAt           DateTime    @default(now())
  leftAt             DateTime?
  durationSeconds    Int         @default(0)
  participationScore Int         @default(0)
  handRaised         Boolean     @default(false)
  lastSeenAt         DateTime    @default(now())
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  session            LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user               User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId, userId, leftAt])
  @@index([sessionId])
  @@index([roomName])
  @@index([userId])
  @@index([joinedAt])
  @@schema("AxelmondResearchLab")
}

model LiveActionLog {
  id             String       @id @default(cuid())
  sessionId      String?
  roomName       String
  actorId        String?
  actorRole      UserRole?
  action         String
  targetIdentity String?
  targetName     String?
  details        Json         @default("{}")
  createdAt      DateTime     @default(now())
  session        LiveSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  actor          User?        @relation("LiveActionActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([roomName])
  @@index([actorId])
  @@index([createdAt])
  @@schema("AxelmondResearchLab")
}

model RefreshToken {
  id            String    @id @default(cuid())
  userId        String
  token         String    @unique
  csrfTokenHash String?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  revokedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, revokedAt, expiresAt])
  @@schema("AxelmondResearchLab")
}

model TotpRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("AxelmondResearchLab")
}

model WebAuthnCredential {
  id               String    @id @default(cuid())
  userId           String
  credentialId     String    @unique
  credentialIdHash String    @unique
  publicKey        Bytes
  counter          BigInt    @default(0)
  transports       Json      @default("[]")
  deviceName       String?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("AxelmondResearchLab")
}

model SecurityChallenge {
  id         String    @id @default(cuid())
  userId     String?
  kind       String
  payload    Json
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@schema("AxelmondResearchLab")
}

enum ScheduleSessionType {
  COURS
  TD
  TP
  LIVE
  EXAMEN

  @@schema("AxelmondResearchLab")
}

model ProfessorScheduleSession {
  id          String              @id @default(cuid())
  professorId String
  dayOfWeek   Int
  title       String
  moduleName  String
  startTime   String
  endTime     String
  sessionType ScheduleSessionType @default(COURS)
  roomOrLink  String?
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  professor   User                @relation(fields: [professorId], references: [id], onDelete: Cascade)

  @@index([professorId, dayOfWeek])
  @@schema("AxelmondResearchLab")
}

enum StudentStudySessionType {
  REVISION
  COURS
  TD
  TP
  LIVE
  DEVOIR
  EXAMEN

  @@schema("AxelmondResearchLab")
}

model StudentStudyScheduleSession {
  id          String                  @id @default(cuid())
  studentId   String
  dayOfWeek   Int
  title       String
  moduleName  String
  startTime   String
  endTime     String
  sessionType StudentStudySessionType @default(REVISION)
  roomOrLink  String?
  description String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  student     User                    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, dayOfWeek])
  @@schema("AxelmondResearchLab")
}

model ModuleProgress {
  id          String   @id @default(cuid())
  userId      String
  courseId    Int
  moduleId    Int
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, moduleId])
  @@index([userId, courseId])
  @@index([courseId, moduleId])
  @@schema("AxelmondResearchLab")
}

model StudentContentProgress {
  id          String   @id @default(cuid())
  userId      String
  courseId    Int
  moduleId    Int?
  contentKey  String
  contentType String
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, contentKey])
  @@index([userId, courseId])
  @@index([courseId, contentKey])
  @@schema("AxelmondResearchLab")
}

enum StudentObjectiveStatus {
  IN_PROGRESS
  COMPLETED

  @@schema("AxelmondResearchLab")
}

enum StudentObjectiveType {
  CHAPITRE
  TD
  RESUME
  REVISION
  AUTRE

  @@schema("AxelmondResearchLab")
}

enum FocusContentType {
  PODCAST
  VIDEO
  AUDIO_REMINDER
  EDUCATIONAL_RESOURCE
  OTHER

  @@schema("AxelmondResearchLab")
}

enum StudentObjectiveRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY

  @@schema("AxelmondResearchLab")
}

model StudentObjective {
  id                  String                     @id @default(cuid())
  studentId           String
  title               String
  description         String?
  startAt             DateTime
  endAt               DateTime
  status              StudentObjectiveStatus     @default(IN_PROGRESS)
  objectiveType       StudentObjectiveType?
  focusContentTitle   String?
  focusContentUrl     String?
  focusContentType    FocusContentType?
  recurrence          StudentObjectiveRecurrence @default(NONE)
  recurrenceSourceId  String?
  recurrenceCreatedAt DateTime?
  completedAt         DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  student             User                       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, status])
  @@index([studentId, recurrence])
  @@index([studentId, recurrenceSourceId])
  @@index([studentId, startAt])
  @@index([studentId, endAt])
  @@schema("AxelmondResearchLab")
}

enum MessageAttachmentKind {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT

  @@schema("AxelmondResearchLab")
}

model Conversation {
  id           String                    @id @default(cuid())
  directKey    String?                   @unique
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt])
  @@schema("AxelmondResearchLab")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  typingUntil    DateTime?
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@schema("AxelmondResearchLab")
}

model Message {
  id             String              @id @default(cuid())
  conversationId String
  senderId       String
  body           String              @default("")
  createdAt      DateTime            @default(now())
  conversation   Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User                @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  attachments    MessageAttachment[]
  reads          MessageRead[]

  @@index([conversationId, createdAt])
  @@schema("AxelmondResearchLab")
}

model MessageAttachment {
  id         String                @id @default(cuid())
  messageId  String
  kind       MessageAttachmentKind
  fileName   String
  mimeType   String
  sizeBytes  Int
  url        String
  storageKey String?
  message    Message               @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@schema("AxelmondResearchLab")
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@schema("AxelmondResearchLab")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  actionUrl String?
  metadata  Json      @default("{}")
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@schema("AxelmondResearchLab")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@schema("AxelmondResearchLab")
}

enum PaymentProvider {
  PAYPAL
  CENTER
  MOCK

  @@schema("AxelmondResearchLab")
}

enum PaymentStatus {
  COMPLETED
  REFUNDED

  @@schema("AxelmondResearchLab")
}

model Payment {
  id                   String                @id @default(cuid())
  userId               String
  courseId             Int
  provider             PaymentProvider
  externalId           String
  amountMad            Float
  status               PaymentStatus         @default(COMPLETED)
  createdAt            DateTime              @default(now())
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  course               Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  invoice              Invoice?
  centerPaymentRequest CenterPaymentRequest?
  promoCodeUsage       PromoCodeUsage?

  @@unique([provider, externalId])
  @@index([userId, courseId])
  @@schema("AxelmondResearchLab")
}

enum CenterPaymentStatus {
  PENDING_PAYMENT
  UNDER_REVIEW
  PAID
  REJECTED
  EXPIRED
  CANCELLED
  REFUNDED

  @@schema("AxelmondResearchLab")
}

enum CenterPaymentMethod {
  CASH
  CARD_AT_CENTER
  BANK_TRANSFER
  CHECK
  OTHER

  @@schema("AxelmondResearchLab")
}

enum CenterPaymentActorType {
  STUDENT
  ADMIN
  SYSTEM

  @@schema("AxelmondResearchLab")
}

model CenterPaymentRequest {
  id                         String                       @id @default(cuid())
  publicReference            String                       @unique
  openRequestKey             String?                      @unique
  userId                     String
  courseId                   Int
  amountMad                  Float
  currency                   String                       @default("MAD")
  modulePriceSnapshot        Float
  moduleTitleSnapshot        String
  moduleDescriptionSnapshot  String?
  accessDurationDaysSnapshot Int
  hasAiAccessSnapshot        Boolean                      @default(false)
  status                     CenterPaymentStatus          @default(PENDING_PAYMENT)
  expiresAt                  DateTime
  paidAt                     DateTime?
  validatedAt                DateTime?
  validatedByUserId          String?
  paymentMethod              CenterPaymentMethod?
  receivedAmountMad          Float?
  physicalReceiptReference   String?
  generatedReceiptNumber     String?                      @unique
  studentNote                String?
  adminNote                  String?
  publicReason               String?
  paymentId                  String?                      @unique
  enrollmentId               String?
  validationIdempotencyKey   String?                      @unique
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  user                       User                         @relation("CenterPaymentStudent", fields: [userId], references: [id], onDelete: Cascade)
  course                     Course                       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  validatedBy                User?                        @relation("CenterPaymentValidator", fields: [validatedByUserId], references: [id], onDelete: SetNull)
  payment                    Payment?                     @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  enrollment                 Enrollment?                  @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  history                    CenterPaymentStatusHistory[]
  promoCodeUsage             PromoCodeUsage?

  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([validatedByUserId])
  @@index([userId, courseId, status])
  @@schema("AxelmondResearchLab")
}

enum PromoDiscountType {
  PERCENTAGE
  FIXED

  @@schema("AxelmondResearchLab")
}

enum PromoAdministrativeStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  EXPIRED
  DISABLED
  ARCHIVED

  @@schema("AxelmondResearchLab")
}

enum PromoEligibilityScope {
  ALL_STUDENTS
  NEW_STUDENTS
  EXISTING_STUDENTS
  SELECTED_USERS
  SELECTED_FILIERES

  @@schema("AxelmondResearchLab")
}

enum PromoUsageStatus {
  RESERVED
  CONFIRMED
  RELEASED
  CANCELLED
  REFUNDED

  @@schema("AxelmondResearchLab")
}

enum PromoUsageProvider {
  PAYPAL
  CENTER
  FREE

  @@schema("AxelmondResearchLab")
}

model PromoCode {
  id                    String                     @id @default(cuid())
  publicId              String                     @unique
  code                  String                     @unique
  internalName          String
  publicDescription     String?
  internalDescription   String?
  discountType          PromoDiscountType
  discountValue         Decimal                    @db.Decimal(12, 2)
  maximumDiscountAmount Decimal?                   @db.Decimal(12, 2)
  minimumPurchaseAmount Decimal?                   @db.Decimal(12, 2)
  currency              String                     @default("MAD")
  startsAt              DateTime
  endsAt                DateTime
  relativeDuration      Json?
  administrativeStatus  PromoAdministrativeStatus  @default(DRAFT)
  appliesToAllModules   Boolean                    @default(false)
  eligibilityScope      PromoEligibilityScope      @default(ALL_STUDENTS)
  firstPurchaseOnly     Boolean                    @default(false)
  maxTotalUses          Int?
  maxUsesPerUser        Int?
  totalReservedUses     Int                        @default(0)
  totalConfirmedUses    Int                        @default(0)
  stackable             Boolean                    @default(false)
  priority              Int                        @default(0)
  version               Int                        @default(1)
  createdByUserId       String
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  disabledAt            DateTime?
  archivedAt            DateTime?
  createdBy             User                       @relation("PromoCodeCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  modules               PromoCodeModule[]
  eligibleUsers         PromoCodeEligibleUser[]
  eligibleFilieres      PromoCodeEligibleFiliere[]
  usages                PromoCodeUsage[]
  auditLog              PromoCodeAuditLog[]

  @@index([administrativeStatus])
  @@index([startsAt])
  @@index([endsAt])
  @@index([createdByUserId])
  @@index([discountType])
  @@schema("AxelmondResearchLab")
}

model PromoCodeModule {
  promoCodeId String
  courseId    Int
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([promoCodeId, courseId])
  @@index([courseId])
  @@schema("AxelmondResearchLab")
}

model PromoCodeEligibleUser {
  promoCodeId String
  userId      String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([promoCodeId, userId])
  @@index([userId])
  @@schema("AxelmondResearchLab")
}

model PromoCodeEligibleFiliere {
  promoCodeId String
  filiere     String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@id([promoCodeId, filiere])
  @@index([filiere])
  @@schema("AxelmondResearchLab")
}

model PromoCodeUsage {
  id                      String                @id @default(cuid())
  publicReference         String                @unique
  promoCodeId             String
  userId                  String
  courseId                Int
  paymentId               String?               @unique
  centerPaymentRequestId  String?               @unique
  provider                PromoUsageProvider
  status                  PromoUsageStatus      @default(RESERVED)
  externalReference       String?               @unique
  idempotencyKey          String?               @unique
  promoCodeSnapshot       String
  discountTypeSnapshot    PromoDiscountType
  discountValueSnapshot   Decimal               @db.Decimal(12, 2)
  maximumDiscountSnapshot Decimal?              @db.Decimal(12, 2)
  originalPriceSnapshot   Decimal               @db.Decimal(12, 2)
  discountAmountSnapshot  Decimal               @db.Decimal(12, 2)
  finalPriceSnapshot      Decimal               @db.Decimal(12, 2)
  currencySnapshot        String
  promoVersionSnapshot    Int
  reservedAt              DateTime              @default(now())
  confirmedAt             DateTime?
  releasedAt              DateTime?
  expiresAt               DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  promoCode               PromoCode             @relation(fields: [promoCodeId], references: [id], onDelete: Restrict)
  user                    User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  course                  Course                @relation(fields: [courseId], references: [id], onDelete: Restrict)
  payment                 Payment?              @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  centerPaymentRequest    CenterPaymentRequest? @relation(fields: [centerPaymentRequestId], references: [id], onDelete: SetNull)

  @@index([promoCodeId, status])
  @@index([userId, promoCodeId, status])
  @@index([courseId])
  @@index([status, expiresAt])
  @@index([provider])
  @@schema("AxelmondResearchLab")
}

model PromoCodeAuditLog {
  id             String    @id @default(cuid())
  promoCodeId    String
  action         String
  actorUserId    String?
  previousValues Json?
  newValues      Json?
  reason         String?
  createdAt      DateTime  @default(now())
  promoCode      PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  actor          User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([promoCodeId, createdAt])
  @@index([actorUserId])
  @@schema("AxelmondResearchLab")
}

model CenterPaymentStatusHistory {
  id                     String                 @id @default(cuid())
  centerPaymentRequestId String
  previousStatus         CenterPaymentStatus?
  newStatus              CenterPaymentStatus
  changedByUserId        String?
  actorType              CenterPaymentActorType
  reason                 String?
  publicReason           String?
  internalNote           String?
  createdAt              DateTime               @default(now())
  request                CenterPaymentRequest   @relation(fields: [centerPaymentRequestId], references: [id], onDelete: Cascade)
  changedBy              User?                  @relation("CenterPaymentHistoryActor", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([centerPaymentRequestId, createdAt])
  @@index([changedByUserId])
  @@schema("AxelmondResearchLab")
}

model Invoice {
  id          String   @id
  userId      String
  paymentId   String   @unique
  courseTitle String
  amountMad   Float
  status      String
  issuedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([userId, issuedAt])
  @@schema("AxelmondResearchLab")
}

model SiteSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("AxelmondResearchLab")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ip         String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@schema("AxelmondResearchLab")
}

enum DonationStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED

  @@schema("AxelmondResearchLab")
}

model CharityAccessCode {
  id               String             @id @default(cuid())
  codeHash         String             @unique
  codeSuffix       String
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  disabledAt       DateTime?
  createdByAdminId String?
  createdBy        User?              @relation("CreatedCharityCodes", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  usages           CharityCodeUsage[]

  @@index([isActive, createdAt])
  @@schema("AxelmondResearchLab")
}

model CharityCodeUsage {
  id     String            @id @default(cuid())
  userId String
  codeId String
  usedAt DateTime          @default(now())
  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  code   CharityAccessCode @relation(fields: [codeId], references: [id], onDelete: Cascade)

  @@unique([userId, codeId])
  @@index([codeId, usedAt])
  @@schema("AxelmondResearchLab")
}

model CharityEvent {
  id            String   @id @default(cuid())
  title         String
  description   String
  eventDateTime DateTime
  location      String   @default("Au centre Performance Académique")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, eventDateTime])
  @@schema("AxelmondResearchLab")
}

model DonationCampaign {
  id          String     @id @default(cuid())
  title       String
  description String
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  donations   Donation[]

  @@index([isActive, createdAt])
  @@schema("AxelmondResearchLab")
}

model Donation {
  id               String           @id @default(cuid())
  userId           String
  campaignId       String
  amount           Float
  status           DonationStatus   @default(PENDING)
  paymentReference String?
  createdAt        DateTime         @default(now())
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign         DonationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([campaignId, status])
  @@schema("AxelmondResearchLab")
}
